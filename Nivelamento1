import Foundation

var registroAlunos: [(nome: String, nota1: Double, nota2: Double, media: Double)] = []
var nomeAluno: String = ""
var maiorMedia: Double = 0


var habilitador: Bool = true



repeat{
    
    print("Digite o nome do aluno: ")
    var nome: String = readLine() ?? ""
    
    if (nome != "sair") {
        
        print("Digite a primeira nota: ")
        var nota1: Double = Double(readLine() ?? "0") ?? 0
        
        print("Digite a segunda nota: ")
        var nota2: Double = Double(readLine() ?? "0") ?? 0
        
        var media: Double = (nota1 + nota2) / 2
        
        registroAlunos.append((nome, nota1, nota2, media))
    }else{
        habilitador = false
    }
    
    
}while(habilitador)

for aluno in registroAlunos{
    if (aluno.media > maiorMedia){
        maiorMedia = aluno.media
        nomeAluno = aluno.nome
    }
}

print("O nome do aluno com a maior nota é: \(nomeAluno) e a media dele foi de: \(maiorMedia)")


